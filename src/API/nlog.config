<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true"
      internalLogLevel="info"
      internalLogFile="internal-nlog.txt">

  <!-- targets define where to write logs -->
  <targets>
    <!-- File target for all logs -->
    <target xsi:type="File" 
            name="allfile" 
            fileName="logs/diagnostics-${shortdate}.txt"
            layout="${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}"
            archiveEvery="Day"
            archiveNumbering="Rolling"
            maxArchiveFiles="7" />
    
    <!-- Separate file for validation-specific logs -->
    <target xsi:type="File" 
            name="validationfile" 
            fileName="logs/validation-${shortdate}.txt"
            layout="${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}"
            archiveEvery="Day"
            maxArchiveFiles="7" />
    
    <!-- Console target for development -->
    <target xsi:type="Console" 
            name="logconsole"
            layout="${longdate}|${level:uppercase=true}|${message} ${exception:format=tostring}" />
  </targets>

  <!-- rules route logs to targets -->
  <rules>
    <!-- Skip Microsoft logs for validation file -->
    <logger name="Microsoft.*" maxlevel="Info" writeTo="validationfile" final="true" />
    
    <!-- Write all validation logs to validation file -->
    <logger name="SmartFintechFinancial.Modules.Identity.Application.Validators.*" 
            minlevel="Debug" 
            writeTo="validationfile" />
    
    <!-- Write all logs to main file -->
    <logger name="*" minlevel="Debug" writeTo="allfile" />
    
    <!-- Write all logs to console -->
    <logger name="*" minlevel="Info" writeTo="logconsole" />
  </rules>
</nlog>